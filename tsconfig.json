{
  "compilerOptions": {
    "target": "ESNext",
    "lib": ["ESNext"],
    "rootDir": ".",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "paths": {
      "@domain": ["./src/domain"],
      "@domain/*": ["./src/domain/*"],
      "@application": ["./src/application"],
      "@application/*": ["./src/application/*"],
      "@ports": ["./src/ports"],
      "@ports/*": ["./src/ports/*"],
      "@infrastructure": ["./src/infrastructure"],
      "@infrastructure/*": ["./src/infrastructure/*"],
      "@shared": ["./src/shared"],
      "@shared/*": ["./src/shared/*"]
    },
    "resolveJsonModule": true,
    "types": ["node"],
    "strict": true,
    "declaration": false,
    "declarationMap": false,
    "noEmit": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedDeclarations": false,
    "skipLibCheck": true
  },
  "include": ["src/**/*.ts", "vitest.config.ts", "tsdown.config.ts"],
  "exclude": ["node_modules", "dist", "reports", "coverage", "stryker-tmp"]
}
